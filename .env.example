# HEMS - Hydraulic Express Mobile Service
# Environment Configuration
# Copy this to .env and update with your values

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE (PostgreSQL)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
POSTGRES_USER=hems_user
POSTGRES_PASSWORD=hemspassword123
POSTGRES_DB=hems_db

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API SERVER (Node.js/Express)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database Connection
DATABASE_URL=postgresql://hems_user:hemspassword123@hems-db:5432/hems_db

# Redis Connection
REDIS_URL=redis://hems-redis:6379

# JWT Authentication
JWT_SECRET=hems_jwt_secret_2026_change_in_production
JWT_EXPIRE=24h

# AI Service URL
AI_SERVICE_URL=http://hems-ai:8000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FRONTEND (React)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
REACT_APP_API_URL=http://localhost:3000
REACT_APP_AI_URL=http://localhost:8000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI SERVICE (Python/FastAPI)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AI_PORT=8000
AI_DATABASE_URL=postgresql://hems_user:hemspassword123@hems-db:5432/hems_db
AI_API_URL=http://hems-api:3000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PGADMIN (Database Management UI)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PGADMIN_DEFAULT_EMAIL=admin@hems.com
PGADMIN_DEFAULT_PASSWORD=admin123

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL: Production Settings
# Uncomment and configure for production
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# NODE_ENV=production
# JWT_SECRET=your_secure_secret_key_here
# POSTGRES_PASSWORD=your_secure_db_password
# REACT_APP_API_URL=https://api.yourdomain.com
# REACT_APP_AI_URL=https://ai.yourdomain.com
